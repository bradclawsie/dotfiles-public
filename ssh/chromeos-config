	User git
	IdentityFile ~/.ssh/id_ed25519
	IdentitiesOnly yes

# BatonPass

Host batonpass-git
	HostName batonpass.systems
	User git
	Port 512
	IdentityFile ~/.ssh/batonpass_ed25519
	IdentitiesOnly yes

Host batonpass-github
	HostName github.com
