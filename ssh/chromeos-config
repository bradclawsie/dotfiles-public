ConnectionAttempts 1
ForwardAgent yes
ForwardX11 no
StrictHostKeyChecking no
KeepAlive yes
AddKeysToAgent yes

# b7j0c

Host b7j0c
	HostName b7j0c.org
	User brad
	IdentityFile ~/.ssh/id_ed25519
	IdentitiesOnly yes
	SetEnv TERM=xterm-256color

Host b7j0c-git
	HostName b7j0c.org
	User git
	IdentityFile ~/.ssh/id_ed25519
	IdentitiesOnly yes

Host sr.ht
	HostName git.sr.ht
	User git
	IdentityFile ~/.ssh/id_ed25519
	IdentitiesOnly yes

Host git.sr.ht
	HostName git.sr.ht
	User git
	IdentityFile ~/.ssh/id_ed25519
	IdentitiesOnly yes

Host github
	HostName github.com
	User git
	IdentityFile ~/.ssh/id_ed25519
	IdentitiesOnly yes

Host codeberg
